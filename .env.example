# ---------------------------------------------------------------------------
# Firebase Web config (client-safe — these are not secrets).
# Create a Firebase project at https://console.firebase.google.com and copy
# the web app config values here, then rename this file to `.env.local`.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Server-side Firebase Admin (KEEP SECRET — used by API routes for lead capture
# and verifying ID tokens). Paste the FULL service-account JSON on ONE line.
# Generate at: Firebase Console → Project settings → Service accounts.
FIREBASE_SERVICE_ACCOUNT=

# Optional: override the Storage bucket (defaults to <project-id>.appspot.com).
FIREBASE_STORAGE_BUCKET=

# Optional: notification email for new lead submissions.
LEADS_NOTIFY_EMAIL=
