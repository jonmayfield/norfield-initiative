rules_version = '2';

// ===========================================================================
// Norfield Initiative — Cloud Storage security rules
//
// Client documents live under users/{uid}/... and are readable only by their
// owner. Uploads are performed server-side (Admin SDK), so client writes are
// denied. Admin SDK bypasses these rules.
// ===========================================================================
service firebase.storage {
  match /b/{bucket}/o {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid}/{allPaths=**} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
